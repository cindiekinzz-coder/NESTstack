name = "your-nesteq-worker"
main = "src/index.ts"
compatibility_date = "2024-01-01"

# NESTknow requires the same D1 and Vectorize bindings as NESTeq.
# Add this to your existing NESTeq worker config — no new worker needed.

[[d1_databases]]
binding = "DB"
database_name = "ai-mind"
database_id = "your-database-id-here"

[[vectorize]]
binding = "VECTORS"
index_name = "ai-mind-vectors"

[ai]
binding = "AI"
